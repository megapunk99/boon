# Boon — Environment Configuration
# Copy this to .env and customize

# Application
BOON_APP_NAME=Boon — Biomedical Waste Intelligence
BOON_APP_VERSION=1.0.0
BOON_DEBUG=true
BOON_HOST=0.0.0.0
BOON_PORT=8000

# CORS (comma-separated frontend origins)
BOON_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# CPCB Compliance Defaults
BOON_CPCB_STATE=Karnataka
BOON_FACILITY_REGISTRATION=KA-BMW-2025-001

# API Keys (optional, for production)
# ODDS_API_KEY=
# NVIDIA_API_KEY=
